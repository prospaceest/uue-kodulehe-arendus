# ── Resend (email) ────────────────────────────────────────────
# Get API key from resend.com → API Keys
# Verify domain: add DNS records for varjuprofiilid.ee (SPF, DKIM)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Clerk (B2B auth) ──────────────────────────────────────────
# Get keys from dashboard.clerk.com → API Keys
# Set allowed domains: varjuprofiilid.ee, localhost:3000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk redirect URLs (update for production)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/konto/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/konto/registreeru
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/konto
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/konto

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://varjuprofiilid.ee
